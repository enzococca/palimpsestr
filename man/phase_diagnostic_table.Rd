\name{phase_diagnostic_table}
\alias{phase_diagnostic_table}
\title{Return a compact diagnostic table}
\usage{phase_diagnostic_table(object)}
\arguments{\item{object}{A \code{sef_fit} object.}}
\value{A data.frame.}
\description{Returns the original input together with dominant phase, phase probabilities, entropy, local SEI, and local energy.}
